# -----------------------------------------------------------------------------
# Spark Lakehouse PoC - Git ignore rules
# -----------------------------------------------------------------------------

# Environment files
.env
.env.*
.env_*
env
env*
env_*

# Local JAR repository generated by prepare_lakehouse_jars_local.sh
# These files are downloaded from public Maven repositories and should not be
# committed because they are large and reproducible.
lakehouse-jars/
lakehouse-jars-work/
**/lakehouse-jars/

# Runtime data and local warehouses
spark-warehouse/
metastore_db/
derby.log
warehouse/
data/

# Logs and temporary files
*.log
*.out
*.err
*.tmp
*.pid
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Creds
creds.txt

# Python cache / local virtual environments
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Java / Scala / build outputs
target/
build/
out/
*.class
*.jar
*.war
*.ear

# IDE/editor metadata
.idea/
.vscode/
*.iml

# Container/runtime generated files
.podman/
.docker/
compose.override.yaml
docker-compose.override.yaml

# Keep repository documentation and configuration templates
!README.md
!docker-compose.yaml
!docker-compose_worker.yaml
!prepare_lakehouse_jars_local.sh
!hive-ivy-urls.txt

# Project Python workspace
!python/spark_pi.py
python/
